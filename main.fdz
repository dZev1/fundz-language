main : void
main {
    let nums : []int = 1::[2::[3::[]]];
    print(filter(nums, isNonZero)).
}

(x) => ((y) => x + y) == (x,y) => x + y

isNonZero : int -> bool
isNonZero(0) { false. }
isNonZero(_) { true. }

filter : []T -> (T -> bool) -> []T
filter([], _) { [] }
filter(x::xs, p) {
    let rec : []T = filter(xs, p);
    if(p(x)) then {
        x::rec.
    } else {
        rec.
    }
}